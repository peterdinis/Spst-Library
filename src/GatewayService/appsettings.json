{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Information"
    }
  },
  "ClientApp": "http://localhost:3000",
  "ReverseProxy": {
    "Routes": [
      {
        "RouteId": "books-route",
        "ClusterId": "books",
        "Match": {
          "Path": "/api/books/{**catch-all}"
        }
      },
      {
        "RouteId": "category-route",
        "ClusterId": "category",
        "Match": {
          "Path": "/api/categories/{**catch-all}"
        }
      },
      {
        "RouteId": "publisher-route",
        "ClusterId": "publisher",
        "Match": {
          "Path": "/api/publishers/{**catch-all}"
        }
      },
      {
        "RouteId": "author-route",
        "ClusterId": "author",
        "Match": {
          "Path": "/api/authors/{**catch-all}"
        }
      },
      {
        "RouteId": "search-route",
        "ClusterId": "search",
        "Match": {
          "Path": "/api/search/{**catch-all}"
        }
      }
    ],
    "Clusters": {
      "books": {
        "Destinations": {
          "booksApi": {
            "Address": "http://books-service:8080"
          }
        }
      },
      "category": {
        "Destinations": {
          "categoryApi": {
            "Address": "http://category-service:8080"
          }
        }
      },
      "publisher": {
        "Destinations": {
          "publisherApi": {
            "Address": "http://publisher-service:8080"
          }
        }
      },
      "author": {
        "Destinations": {
          "authorApi": {
            "Address": "http://author-service:8080"
          }
        }
      },
      "search": {
        "Destinations": {
          "searchApi": {
            "Address": "http://search-service:8080"
          }
        }
      }
    }
  }
}