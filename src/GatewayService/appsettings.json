{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.AspNetCore.HttpLogging": "Information",
      "Yarp": "Information"
    }
  },
  "ClientApp": "http://localhost:3000",
  "ReverseProxy": {
    "Routes": {
      "books-api": {
        "ClusterId": "books-cluster",
        "Match": {
          "Path": "/api/books/{**remainder}"
        },
        "Transforms": [
          { "PathRemovePrefix": "/api/books" }
        ]
      },
      "authors-api": {
        "ClusterId": "authors-cluster",
        "Match": {
          "Path": "/api/authors/{**remainder}"
        },
        "Transforms": [
          { "PathRemovePrefix": "/api/authors" }
        ]
      },
      "categories-api": {
        "ClusterId": "categories-cluster",
        "Match": {
          "Path": "/api/categories/{**remainder}"
        },
        "Transforms": [
          { "PathRemovePrefix": "/api/categories" }
        ]
      }
    },
    "Clusters": {
      "books-cluster": {
        "Destinations": {
          "books-destination": {
            "Address": "http://books-service:8080/"
          }
        }
      },
      "authors-cluster": {
        "Destinations": {
          "authors-destination": {
            "Address": "http://authors-service:8080/"
          }
        }
      },
      "categories-cluster": {
        "Destinations": {
          "categories-destination": {
            "Address": "http://categories-service:8080/"
          }
        }
      }
    }
  }
}