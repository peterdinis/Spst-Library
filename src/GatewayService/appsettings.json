{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.AspNetCore.HttpLogging": "Information"
    }
  },
  "ClientApp": "http://localhost:3000",
  "ReverseProxy": {
    "Routes": [
      {
        "RouteId": "books-route",
        "ClusterId": "books-cluster",
        "Match": {
          "Path": "/api/books/{**catch-all}"
        }
      },
      {
        "RouteId": "authors-route",
        "ClusterId": "authors-cluster", 
        "Match": {
          "Path": "/api/authors/{**catch-all}"
        }
      },
      {
        "RouteId": "categories-route",
        "ClusterId": "categories-cluster",
        "Match": {
          "Path": "/api/categories/{**catch-all}"
        }
      },
      {
        "RouteId": "publishers-route",
        "ClusterId": "publishers-cluster",
        "Match": {
          "Path": "/api/publishers/{**catch-all}"
        }
      },
      {
        "RouteId": "search-route",
        "ClusterId": "search-cluster",
        "Match": {
          "Path": "/api/search/{**catch-all}"
        }
      }
    ],
    "Clusters": {
      "books-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://books-service:8080"
          }
        }
      },
      "authors-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://author-service:8080"
          }
        }
      },
      "categories-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://category-service:8080"
          }
        }
      },
      "publishers-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://publisher-service:8080"
          }
        }
      },
      "search-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://search-service:8080"
          }
        }
      }
    }
  }
}