{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "ClientApp": "http://localhost:3000",
  "ReverseProxy": {
    "Routes": {
      "books-route": {
        "ClusterId": "books",
        "Match": {
          "Path": "/api/books/{**catch-all}"
        },
        "Transforms": [
          { "PathPattern": "/api/books/{**catch-all}" }
        ]
      },
      "authors-route": {
        "ClusterId": "authors",
        "Match": {
          "Path": "/api/authors/{**catch-all}"
        },
        "Transforms": [
          { "PathPattern": "/api/authors/{**catch-all}" }
        ]
      },
      "categories-route": {
        "ClusterId": "categories", 
        "Match": {
          "Path": "/api/categories/{**catch-all}"
        },
        "Transforms": [
          { "PathPattern": "/api/categories/{**catch-all}" }
        ]
      },
      "publishers-route": {
        "ClusterId": "publishers",
        "Match": {
          "Path": "/api/publishers/{**catch-all}"
        },
        "Transforms": [
          { "PathPattern": "/api/publishers/{**catch-all}" }
        ]
      },
      "search-route": {
        "ClusterId": "search",
        "Match": {
          "Path": "/api/search/{**catch-all}"
        },
        "Transforms": [
          { "PathPattern": "/api/search/{**catch-all}" }
        ]
      }
    },
    "Clusters": {
      "books": {
        "Destinations": {
          "books-destination": {
            "Address": "http://books-service:8080/"
          }
        }
      },
      "authors": {
        "Destinations": {
          "authors-destination": {
            "Address": "http://author-service:8080/"
          }
        }
      },
      "categories": {
        "Destinations": {
          "categories-destination": {
            "Address": "http://category-service:8080/"
          }
        }
      },
      "publishers": {
        "Destinations": {
          "publishers-destination": {
            "Address": "http://publisher-service:8080/"
          }
        }
      },
      "search": {
        "Destinations": {
          "search-destination": {
            "Address": "http://search-service:8080/"
          }
        }
      }
    }
  }
}