{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.AspNetCore.HttpLogging": "Information",
      "Yarp": "Information"
    }
  },
  "ClientApp": "http://localhost:3000",
  "ReverseProxy": {
    "Routes": {
      "books-api": {
        "ClusterId": "books-cluster",
        "Match": {
          "Path": "/api/books/{**remainder}"
        },
        "Transforms": [
          { "PathRemovePrefix": "/api/books" }
        ]
      },
      "authors-api": {
        "ClusterId": "authors-cluster",
        "Match": {
          "Path": "/api/authors/{**remainder}"
        },
        "Transforms": [
          { "PathRemovePrefix": "/api/authors" }
        ]
      },
      "categories-api": {
        "ClusterId": "categories-cluster",
        "Match": {
          "Path": "/api/categories/{**remainder}"
        },
        "Transforms": [
          { "PathRemovePrefix": "/api/categories" }
        ]
      },
      "orders-route": {
        "ClusterId": "orders-cluster",
        "Match": {
          "Path": "/api/orders/{**catch-all}"
        },
        "Transforms": [
          {
            "PathRemovePrefix": "/api/orders"
          }
        ]
      }
    },
    "Clusters": {
      "books-cluster": {
        "Destinations": {
          "books-destination": {
            "Address": "http://books-service:8080/"
          }
        }
      },
      "authors-cluster": {
        "Destinations": {
          "authors-service": {
            "Address": "http://author-service:8080/"
          }
        }
      },
      "categories-cluster": {
        "Destinations": {
          "categories-service": {
            "Address": "http://category-service:8080/"
          }
        }
      },
      "publishers-cluster": {
        "Destinations": {
          "publishers-service": {
            "Address": "http://publishers-service:8080/"
          }
        }
      },
      "search-cluster": {
        "Destinations": {
          "search-service": {
            "Address": "http://search-service:8080/"
          }
        }
      },
      "orders-cluster": {
        "Destinations": {
          "orders-service": {
            "Address": "http://order-service:8080/"
          }
        }
      }
    }
  }
}