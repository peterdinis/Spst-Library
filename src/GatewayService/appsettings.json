{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.AspNetCore.HttpLogging": "Information",
      "Yarp": "Information"
    }
  },
  "ClientApp": "http://localhost:3000",
  "ReverseProxy": {
    "Routes": {
      "books-api": {
        "ClusterId": "books-cluster",
        "Match": {
          "Path": "/api/books/{**catch-all}"
        }
      },
      "authors-api": {
        "ClusterId": "authors-cluster",
        "Match": {
          "Path": "/api/authors/{**catch-all}"
        }
      },
      "categories-api": {
        "ClusterId": "categories-cluster",
        "Match": {
          "Path": "/api/categories/{**catch-all}"
        }
      },
      "orders-api": {
        "ClusterId": "orders-cluster",
        "Match": {
          "Path": "/api/orders/{**catch-all}"
        }
      }
    },
    "Clusters": {
      "books-cluster": {
        "Destinations": {
          "books-destination": {
            "Address": "http://books-service:8080/api/books/"
          }
        }
      },
      "authors-cluster": {
        "Destinations": {
          "authors-destination": {
            "Address": "http://author-service:8080/api/authors/"
          }
        }
      },
      "categories-cluster": {
        "Destinations": {
          "categories-destination": {
            "Address": "http://category-service:8080/api/categories/"
          }
        }
      },
      "orders-cluster": {
        "Destinations": {
          "orders-destination": {
            "Address": "http://order-service:8080/api/orders/"
          }
        }
      }
    }
  }
}